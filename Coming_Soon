<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Solar Circle | Coming Soon</title>
    <style>
        body {
            background-color: #f8f9fa; /* Off-white texture */
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #002d5b; /* Dark blue from your logo */
            text-align: center;
        }

        /* The Animation Container */
        .stage {
            position: relative;
            width: 200px;
            height: 150px;
            margin-bottom: 20px;
        }

        /* The Solar Panel */
        .panel {
            position: absolute;
            bottom: 10px;
            left: 50px;
            width: 100px;
            height: 60px;
            background: #0077b6; /* Solar Blue */
            border: 3px solid #002d5b;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            grid-template-rows: repeat(2, 1fr);
            gap: 2px;
            padding: 2px;
            transition: filter 1s ease;
        }

        .cell { background: rgba(255,255,255,0.1); }

        /* The Cloud */
        .cloud {
            position: absolute;
            top: 20px;
            width: 80px;
            height: 40px;
            background: white;
            border-radius: 50px;
            box-shadow: 10px 10px 20px rgba(0,0,0,0.05);
            animation: drift 8s infinite linear;
        }
        .cloud::after, .cloud::before {
            content: '';
            position: absolute;
            background: white;
            border-radius: 50%;
        }
        .cloud::after { width: 40px; height: 40px; top: -20px; left: 10px; }
        .cloud::before { width: 30px; height: 30px; top: -15px; left: 35px; }

        /* Animation Logic */
        @keyframes drift {
            0% { left: -100px; opacity: 0; }
            10% { opacity: 1; }
            45%, 55% { filter: brightness(1); } /* Light on panel */
            50% { left: 60px; } /* Directly over panel */
            90% { opacity: 1; }
            100% { left: 250px; opacity: 0; }
        }

        h1 { margin: 10px 0 5px 0; letter-spacing: 2px; font-weight: 800; }
        p { margin: 0; font-style: italic; color: #ff8c00; font-weight: bold; }
        .status { margin-top: 30px; font-size: 0.8rem; color: #666; }
    </style>
</head>
<body>

    <div class="stage">
        <div class="panel">
            <div class="cell"></div><div class="cell"></div><div class="cell"></div><div class="cell"></div>
            <div class="cell"></div><div class="cell"></div><div class="cell"></div><div class="cell"></div>
        </div>
        <div class="cloud"></div>
    </div>

    <h1>THE SOLAR CIRCLE</h1>
    <p>Waiting for the sunshine...</p>

    <div class="status">
        Real data. Shared simply.<br>
        <strong>Launching May 2026</strong>
    </div>

</body>
</html>
